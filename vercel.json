{
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/backgrounds/(.*)", "dest": "/public/backgrounds/$1" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/apple-touch-icon.png", "dest": "/public/apple-touch-icon.png" },
    { "src": "/watermark.png", "dest": "/public/watermark.png" },
    { "src": "/favicon-(.*).png", "dest": "/public/favicon-$1.png" }
  ],
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/poster", "destination": "/api/poster" },
    { "source": "/api/poster", "destination": "/api/poster" },
    { "source": "/upcoming-events", "destination": "/api/upcoming_events" },
    { "source": "/api/telegram", "destination": "/api/telegram_webhook" },
    { "source": "/omer-info", "destination": "/api/omer_info" }
  ],
  "crons": [
    { "path": "/api/shabbat_reminder", "schedule": "0 5 * * *" }
  ]
}
